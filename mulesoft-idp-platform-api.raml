#%RAML 1.0
securitySchemes:
  mulesoft-basic-login:
    type: Basic Authentication
    describedBy:
      responses:
        "200":
          body:
            application/json:
              properties:
                access_token:
                  example: d127e2ec-a703-4e2a-8629-e9158804748ble
                  type: string
                token_type:
                  example: bearer
                  type: string
title: MuleSoft IDP Platform API
baseUri: https://anypoint.mulesoft.com
mediaType:
  - application/json
version: v1
protocols:
  - HTTPS
