                            required: true
                            confidenceThreshold: 80
                          surname:
                            hidden: false
                            prompt: what is the surname found next to the left label "1."
                            source: document
                            required: true
                            confidenceThreshold: 80
                          other_names:
                            hidden: false
                            prompt: what are the names found next to the left label "2."
                            source: document
                            required: true
                            confidenceThreshold: 80
                          entitlements:
                            hidden: false
                            prompt: read the letters including spaces but ignoring the forward slashes that are found to right of the label "9." and sometimes underneath the photo
